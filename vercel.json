{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "functions": {
    "app/api/objectives/[id]/route.ts": { "maxDuration": 60 },
    "app/api/north/extract-objectives/route.ts": { "maxDuration": 60 },
    "app/api/north/chat/route.ts": { "maxDuration": 60 },
    "app/api/plan/generate/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/retention", "schedule": "0 9 * * *" }
  ]
}
